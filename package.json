{
	"name": "@package-pal/root",
	"license": "MIT",
	"type": "module",
	"private": true,
	"scripts": {
		"prepare": "husky",
		"lint": "eslint --fix && prettier --log-level warn --write \"**/*.{md,json,yml}\"",
		"check": "tsc --build && tsc --build --clean",
		"test": "bun test --only-failures",
		"build": "bun run scripts/build-package.ts",
		"build:compile-cli": "bun scripts/compile-cli-target-packages.ts",
		"build:all": "bun run build util && bun run build core && bun run build adapter-package-json && bun run build adapter-csproj && bun run build cli && bun run build:compile-cli"
	},
	"workspaces": {
		"packages": [
			"packages/*"
		],
		"catalog": {
			"typescript": "^6.0.3",
			"@types/bun": "^1.3.14"
		}
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@package-pal/util": "link:@package-pal/util",
		"@package-pal/cli": "link:@package-pal/cli",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/bun": "^1.3.14",
		"@typescript-eslint/parser": "^8.61.0",
		"eslint": "^10.4.1",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-jsdoc": "^63.0.2",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0"
	},
	"sideEffects": false
}
