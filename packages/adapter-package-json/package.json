{
	"name": "@package-pal/adapter-package-json",
	"version": "0.0.1",
	"description": "JS package.json adapter for PackagePal.",
	"private": true,
	"keywords": [
		"package",
		"pal",
		"ppal",
		"adapter",
		"package-json"
	],
	"license": "MIT",
	"type": "module",
	"exports": "./src/index.ts",
	"devDependencies": {
		"typescript": "catalog:"
	},
